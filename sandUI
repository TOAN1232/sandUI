--[[
    SandUI Library - Portrait Edition (Upgraded: Resizable & Nameable)
    Theme: Sand (Warm Beige/Orange)
    Author: Gemini
--]]

local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

local SandUI = {}

function SandUI:CreateWindow(title)
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "SandUI_" .. math.random(100, 999)
    ScreenGui.Parent = CoreGui
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    -- Main Frame (Portrait)
    local Main = Instance.new("Frame")
    Main.Name = "Main"
    Main.Parent = ScreenGui
    Main.BackgroundColor3 = Color3.fromRGB(244, 226, 198) -- Light Sand
    Main.Position = UDim2.new(0.5, -150, 0.5, -150)
    Main.Size = UDim2.new(0, 300, 0, 350)
    Main.BorderSizePixel = 0
    Main.ClipsDescendants = true
    Main.Active = true

    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, 8)
    UICorner.Parent = Main

    local UIStroke = Instance.new("UIStroke")
    UIStroke.Color = Color3.fromRGB(194, 178, 128) -- Darker Sand
    UIStroke.Thickness = 2
    UIStroke.Parent = Main

    -- Header
    local Header = Instance.new("Frame")
    Header.Name = "Header"
    Header.Parent = Main
    Header.BackgroundColor3 = Color3.fromRGB(210, 180, 140) -- Tan
    Header.Size = UDim2.new(1, 0, 0, 30)
    Header.BorderSizePixel = 0

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Parent = Header
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Size = UDim2.new(1, -10, 1, 0)
    TitleLabel.Position = UDim2.new(0, 10, 0, 0)
    TitleLabel.Font = Enum.Font.Ubuntu
    TitleLabel.Text = title or "SandUI"
    TitleLabel.TextColor3 = Color3.fromRGB(80, 60, 40)
    TitleLabel.TextSize = 14
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- Sidebar (Tabs)
    local Sidebar = Instance.new("Frame")
    Sidebar.Name = "Sidebar"
    Sidebar.Parent = Main
    Sidebar.BackgroundColor3 = Color3.fromRGB(230, 210, 180)
    Sidebar.Position = UDim2.new(0, 0, 0, 30)
    Sidebar.Size = UDim2.new(0, 80, 1, -30)
    Sidebar.BorderSizePixel = 0

    local TabContainer = Instance.new("ScrollingFrame")
    TabContainer.Parent = Sidebar
    TabContainer.Size = UDim2.new(1, 0, 1, -20)
    TabContainer.Position = UDim2.new(0, 0, 0, 5)
    TabContainer.BackgroundTransparency = 1
    TabContainer.ScrollBarThickness = 0
    
    local TabListLayout = Instance.new("UIListLayout")
    TabListLayout.Parent = TabContainer
    TabListLayout.Padding = UDim.new(0, 2)
    TabListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    -- Page Area
    local PageContainer = Instance.new("Frame")
    PageContainer.Name = "PageContainer"
    PageContainer.Parent = Main
    PageContainer.BackgroundTransparency = 1
    PageContainer.Position = UDim2.new(0, 85, 0, 35)
    PageContainer.Size = UDim2.new(1, -90, 1, -40)

    -- Resize Handle (Bottom Right Corner)
    local ResizeHandle = Instance.new("ImageLabel")
    ResizeHandle.Name = "ResizeHandle"
    ResizeHandle.Parent = Main
    ResizeHandle.BackgroundTransparency = 1
    ResizeHandle.Position = UDim2.new(1, -15, 1, -15)
    ResizeHandle.Size = UDim2.new(0, 15, 0, 15)
    ResizeHandle.Image = "rbxassetid://12133575604" -- Diagonal Resize Icon
    ResizeHandle.ImageColor3 = Color3.fromRGB(150, 120, 80)
    ResizeHandle.ZIndex = 5

    -- Logic: Dragging
    local dragging, dragStart, startPos
    Header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    Header.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- Logic: Resizing
    local resizing = false
    local resStartPos, resStartSize

    ResizeHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = true
            resStartPos = input.Position
            resStartSize = Main.Size
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - resStartPos
            local newWidth = math.max(250, resStartSize.X.Offset + delta.X)
            local newHeight = math.max(200, resStartSize.Y.Offset + delta.Y)
            Main.Size = UDim2.new(0, newWidth, 0, newHeight)
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = false
        end
    end)

    -- Window Object
    local Window = {}
    local firstTab = true

    -- Function to rename the UI
    function Window:SetTitle(newTitle)
        TitleLabel.Text = newTitle
    end

    function Window:CreateTab(tabName)
        local TabBtn = Instance.new("TextButton")
        TabBtn.Parent = TabContainer
        TabBtn.Size = UDim2.new(0, 70, 0, 25)
        TabBtn.BackgroundColor3 = Color3.fromRGB(210, 180, 140)
        TabBtn.Text = tabName
        TabBtn.Font = Enum.Font.Ubuntu
        TabBtn.TextColor3 = Color3.fromRGB(80, 60, 40)
        TabBtn.TextSize = 11
        
        local TabCorner = Instance.new("UICorner")
        TabCorner.CornerRadius = UDim.new(0, 4)
        TabCorner.Parent = TabBtn

        local Page = Instance.new("ScrollingFrame")
        Page.Parent = PageContainer
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 2
        Page.ScrollBarImageColor3 = Color3.fromRGB(194, 178, 128)
        Page.BorderSizePixel = 0
        
        local PageLayout = Instance.new("UIListLayout")
        PageLayout.Parent = Page
        PageLayout.Padding = UDim.new(0, 5)
        PageLayout.SortOrder = Enum.SortOrder.LayoutOrder

        PageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Page.CanvasSize = UDim2.new(0, 0, 0, PageLayout.AbsoluteContentSize.Y)
        end)

        if firstTab then
            Page.Visible = true
            TabBtn.BackgroundColor3 = Color3.fromRGB(180, 150, 110)
            TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            firstTab = false
        end

        TabBtn.MouseButton1Click:Connect(function()
            for _, p in pairs(PageContainer:GetChildren()) do
                if p:IsA("ScrollingFrame") then p.Visible = false end
            end
            for _, b in pairs(TabContainer:GetChildren()) do
                if b:IsA("TextButton") then
                    b.BackgroundColor3 = Color3.fromRGB(210, 180, 140)
                    b.TextColor3 = Color3.fromRGB(80, 60, 40)
                end
            end
            Page.Visible = true
            TabBtn.BackgroundColor3 = Color3.fromRGB(180, 150, 110)
            TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        end)

        local Elements = {}

        function Elements:CreateButton(text, callback)
            local Btn = Instance.new("TextButton")
            Btn.Parent = Page
            Btn.Size = UDim2.new(1, 0, 0, 30)
            Btn.BackgroundColor3 = Color3.fromRGB(230, 200, 160)
            Btn.Font = Enum.Font.Ubuntu
            Btn.Text = text
            Btn.TextColor3 = Color3.fromRGB(80, 60, 40)
            Btn.TextSize = 12
            Btn.AutoButtonColor = true
            Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 4)
            Btn.MouseButton1Click:Connect(callback)
        end

        function Elements:CreateToggle(text, default, callback)
            local state = default or false
            local Tgl = Instance.new("TextButton")
            Tgl.Parent = Page
            Tgl.Size = UDim2.new(1, 0, 0, 30)
            Tgl.BackgroundColor3 = Color3.fromRGB(230, 200, 160)
            Tgl.Text = ""
            Instance.new("UICorner", Tgl).CornerRadius = UDim.new(0, 4)

            local Label = Instance.new("TextLabel")
            Label.Parent = Tgl
            Label.Size = UDim2.new(1, -30, 1, 0)
            Label.Position = UDim2.new(0, 5, 0, 0)
            Label.BackgroundTransparency = 1
            Label.Text = text
            Label.Font = Enum.Font.Ubuntu
            Label.TextColor3 = Color3.fromRGB(80, 60, 40)
            Label.TextSize = 11
            Label.TextXAlignment = Enum.TextXAlignment.Left

            local Ind = Instance.new("Frame")
            Ind.Parent = Tgl
            Ind.Size = UDim2.new(0, 12, 0, 12)
            Ind.Position = UDim2.new(1, -20, 0.5, -6)
            Ind.BackgroundColor3 = state and Color3.fromRGB(150, 120, 80) or Color3.fromRGB(255, 255, 255)
            Instance.new("UICorner", Ind).CornerRadius = UDim.new(1, 0)

            Tgl.MouseButton1Click:Connect(function()
                state = not state
                TweenService:Create(Ind, TweenInfo.new(0.2), {BackgroundColor3 = state and Color3.fromRGB(150, 120, 80) or Color3.fromRGB(255, 255, 255)}):Play()
                callback(state)
            end)
        end

        function Elements:CreateSlider(text, min, max, default, callback)
            local SliderFrame = Instance.new("Frame")
            SliderFrame.Parent = Page
            SliderFrame.Size = UDim2.new(1, 0, 0, 40)
            SliderFrame.BackgroundColor3 = Color3.fromRGB(230, 200, 160)
            Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 4)

            local Label = Instance.new("TextLabel")
            Label.Parent = SliderFrame
            Label.Size = UDim2.new(1, -10, 0, 15)
            Label.Position = UDim2.new(0, 5, 0, 2)
            Label.BackgroundTransparency = 1
            Label.Text = text .. ": " .. default
            Label.Font = Enum.Font.Ubuntu
            Label.TextColor3 = Color3.fromRGB(80, 60, 40)
            Label.TextSize = 10
            Label.TextXAlignment = Enum.TextXAlignment.Left

            local Bar = Instance.new("Frame")
            Bar.Parent = SliderFrame
            Bar.Size = UDim2.new(1, -10, 0, 4)
            Bar.Position = UDim2.new(0, 5, 0, 25)
            Bar.BackgroundColor3 = Color3.fromRGB(210, 180, 140)

            local Fill = Instance.new("Frame")
            Fill.Parent = Bar
            Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
            Fill.BackgroundColor3 = Color3.fromRGB(150, 120, 80)
            Fill.BorderSizePixel = 0

            local function update(input)
                local pos = math.clamp((input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                local value = math.floor(min + (max - min) * pos)
                Fill.Size = UDim2.new(pos, 0, 1, 0)
                Label.Text = text .. ": " .. value
                callback(value)
            end

            local sliding = false
            SliderFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliding = true
                    update(input)
                end
            end)

            UIS.InputChanged:Connect(function(input)
                if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                    update(input)
                end
            end)

            UIS.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliding = false
                end
            end)
        end

        function Elements:CreateInput(placeholder, callback)
            local Box = Instance.new("TextBox")
            Box.Parent = Page
            Box.Size = UDim2.new(1, 0, 0, 30)
            Box.BackgroundColor3 = Color3.fromRGB(255, 245, 230)
            Box.PlaceholderText = placeholder
            Box.Text = ""
            Box.Font = Enum.Font.Ubuntu
            Box.TextColor3 = Color3.fromRGB(80, 60, 40)
            Box.TextSize = 12
            Instance.new("UICorner", Box).CornerRadius = UDim.new(0, 4)

            Box.FocusLost:Connect(function(enter)
                if enter then callback(Box.Text) end
            end)
        end

        return Elements
    end

    return Window
end

return SandUI
